# Entrenar Environment Variables
# Copy to .env and customize for your environment

# Training
ENTRENAR_LOG_LEVEL=info
ENTRENAR_SEED=42
ENTRENAR_OUTPUT_DIR=./output

# GPU
CUDA_VISIBLE_DEVICES=0
ENTRENAR_GPU_MEMORY_FRACTION=0.9
ENTRENAR_MIXED_PRECISION=true

# Distributed Training
ENTRENAR_WORLD_SIZE=1
ENTRENAR_RANK=0
ENTRENAR_COORDINATOR_ADDR=0.0.0.0:9000

# Sovereign Mode
ENTRENAR_SOVEREIGN_MODE=false
ENTRENAR_DATA_RESIDENCY=local
ENTRENAR_OFFLINE=false

# Monitoring
ENTRENAR_METRICS_DIR=./metrics
ENTRENAR_CHECKPOINT_INTERVAL=1000
ENTRENAR_LOG_INTERVAL=100
